{
  "@platforms": [
    "android",
    "iPhone",
    "iPad"
  ],
  "id": "__UNI__7050621",
  "name": "固始县外卖骑手端",
  "version": {
    "name": "1.0.0",
    "code": "100"
  },
  "description": "骑手专用接单配送应用",
  "developer": {
    "name": "",
    "email": "",
    "url": ""
  },
  "permissions": {
    "Speech": {},
    "Push": {},
    "UniNView": {
      "description": "UniNView原生渲染"
    }
  },
  "plus": {
    "useragent": {
      "value": "uni-app",
      "concatenate": true
    },
    "splashscreen": {
      "target": "id:1",
      "autoclose": true,
      "waiting": true,
      "delay": 0
    },
    "popGesture": "close",
    "launchwebview": {
      "id": "1",
      "kernel": "WKWebview"
    },
    "usingComponents": true,
    "nvueCompiler": "uni-app",
    "compilerVersion": 3,
    "distribute": {
      "google": {
        "packagename": "com.gushi.waimai.rider",
        "minSdkVersion": 24,
        "packagingOptions": [
          "pickFirst 'okhttp3/internal/publicsuffix/publicsuffixes.gz'"
        ],
        "usesCleartextTraffic": true,
        "permissions": [
          "<uses-permission android:name=\"android.permission.INTERNET\"/>",
          "<uses-permission android:name=\"android.permission.ACCESS_NETWORK_STATE\"/>",
          "<uses-permission android:name=\"android.permission.ACCESS_WIFI_STATE\"/>",
          "<uses-permission android:name=\"android.permission.CHANGE_WIFI_STATE\"/>",
          "<uses-permission android:name=\"android.permission.ACCESS_COARSE_LOCATION\"/>",
          "<uses-permission android:name=\"android.permission.ACCESS_FINE_LOCATION\"/>",
          "<uses-permission android:name=\"android.permission.ACCESS_BACKGROUND_LOCATION\"/>",
          "<uses-permission android:name=\"android.permission.ACCESS_LOCATION_EXTRA_COMMAND\"/>",
          "<uses-permission android:name=\"android.permission.WRITE_EXTERNAL_STORAGE\"/>",
          "<uses-permission android:name=\"android.permission.READ_EXTERNAL_STORAGE\"/>",
          "<uses-permission android:name=\"android.permission.VIBRATE\"/>"
        ]
      },
      "apple": {
        "dSYMs": false
      },
      "plugins": {
        "audio": {
          "mp3": {
            "description": "Android平台录音支持MP3格式文件"
          }
        }
      }
    },
    "nativePlugins": {
      "TencentNaviModule": {
        "__plugin_info__": {
          "name": "腾讯原生导航测试插件",
          "description": "骑手端腾讯原生导航测试壳插件",
          "platforms": "Android",
          "url": "",
          "android_package_name": "",
          "ios_bundle_id": "",
          "isCloud": false,
          "bought": -1,
          "pid": "",
          "parameters": {}
        }
      }
    },
    "statusbar": {
      "immersed": "supportedDevice",
      "style": "light",
      "background": "#1890FF"
    },
    "allowsInlineMediaPlayback": true,
    "safearea": {
      "background": "#ffffff",
      "bottom": {
        "offset": "auto"
      }
    },
    "uni-app": {
      "control": "uni-v3",
      "vueVersion": "3",
      "compilerVersion": "5.07",
      "nvueCompiler": "uni-app",
      "renderer": "auto",
      "nvue": {
        "flex-direction": "column"
      },
      "nvueLaunchMode": "normal",
      "webView": {
        "minUserAgentVersion": "49.0"
      }
    },
    "tabBar": {
      "position": "bottom",
      "color": "#999999",
      "selectedColor": "#1890FF",
      "borderStyle": "rgba(0,0,0,0.4)",
      "blurEffect": "none",
      "fontSize": "16px",
      "iconWidth": "28px",
      "spacing": "6px",
      "height": "62px",
      "list": [
        {
          "pagePath": "pages/index/index",
          "text": "📱 工作台"
        },
        {
          "pagePath": "pages/profile/index",
          "text": "👤 我的"
        }
      ],
      "backgroundColor": "#ffffff",
      "selectedIndex": 0,
      "shown": true
    }
  },
  "app-harmony": {
    "useragent": {
      "value": "uni-app",
      "concatenate": true
    },
    "safearea": {
      "background": "#ffffff",
      "bottom": {
        "offset": "auto"
      }
    }
  },
  "launch_path": "__uniappview.html"
}